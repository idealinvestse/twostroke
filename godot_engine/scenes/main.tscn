[sub_resource type="GDScript" id="GDScript_orbit"]
script/source = "extends Node

@export var camera: NodePath
@export var rotate_speed: float = 0.005
@export var zoom_speed: float = 0.1
@export var min_distance: float = 1.0
@export var max_distance: float = 5.0

var _camera: Camera3D = null
var _distance: float = 2.0
var _rot_x: float = 0.0
var _rot_y: float = 0.0
var _dragging: bool = false

func _ready():
	if camera:
		_camera = get_node(camera)
	_update_position()

func _input(event):
	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_LEFT:
			_dragging = event.pressed
		elif event.button_index == MOUSE_BUTTON_WHEEL_UP:
			_distance = maxf(_distance - zoom_speed, min_distance)
			_update_position()
		elif event.button_index == MOUSE_BUTTON_WHEEL_DOWN:
			_distance = minf(_distance + zoom_speed, max_distance)
			_update_position()
	
	if event is InputEventMouseMotion and _dragging:
		_rot_x -= event.relative.x * rotate_speed
		_rot_y -= event.relative.y * rotate_speed
		_rot_y = clampf(_rot_y, -PI/2 + 0.1, PI/2 - 0.1)
		_update_position()

func _update_position():
	if not _camera:
		return
	
	var pos = Vector3(
		sin(_rot_x) * cos(_rot_y) * _distance,
		sin(_rot_y) * _distance,
		cos(_rot_x) * cos(_rot_y) * _distance
	)
	
	_camera.position = pos
	_camera.look_at(Vector3.ZERO, Vector3.UP)
"

